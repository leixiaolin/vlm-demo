# Large model provider for image description.
# Supported values:
# - openai: OpenAI Responses API, supports image input.
# - openai_chat: OpenAI-compatible Chat Completions API that supports image_url.
# - deepseek: DeepSeek official Chat Completions API is text-only for this workflow; do not use for image description.
# - mock: local pipeline validation without remote calls.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini

# API settings.
OPENAI_API_KEY=
LLM_API_KEY_ENV=OPENAI_API_KEY

# OpenAI Responses API endpoint for LLM_PROVIDER=openai.
OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses

# OpenAI-compatible multimodal chat endpoint for LLM_PROVIDER=openai_chat.
# Example: https://api.openai.com/v1/chat/completions
OPENAI_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions

# Image description test defaults.
IMAGE_DESCRIPTION_MANIFEST=data/office_images/evaluation_manifest_collected.csv
IMAGE_DESCRIPTION_PROMPT_FILE=prompts/image_description.md
IMAGE_DESCRIPTION_OUTPUT=outputs/image_description_results.jsonl
IMAGE_DESCRIPTION_LIMIT=5
IMAGE_DESCRIPTION_OFFSET=0
IMAGE_DESCRIPTION_DETAIL=low
IMAGE_DESCRIPTION_TIMEOUT_SECONDS=120
IMAGE_DESCRIPTION_SLEEP_SECONDS=1
IMAGE_DESCRIPTION_MAX_OUTPUT_TOKENS=700

# Public image collection defaults.
OFFICE_IMAGE_TARGET_COUNT=150
OFFICE_IMAGE_QUERY_FILE=data/office_image_queries.txt
OFFICE_IMAGE_THUMB_WIDTH=900
OFFICE_IMAGE_DELAY_SECONDS=0.1

# Local Ovis2.5-2B evaluation defaults.
OVIS_MODEL_ID=AIDC-AI/Ovis2.5-2B
OVIS_EVAL_MANIFEST=data/office_images/evaluation_manifest_collected.csv
OVIS_EVAL_PROMPT_FILE=prompts/ovis_security_risk_detection_compact.md
OVIS_EVAL_OUTPUT=outputs/ovis25_2b_results.jsonl
OVIS_EVAL_SUMMARY=outputs/ovis25_2b_summary.json
OVIS_EVAL_LIMIT=15
OVIS_EVAL_OFFSET=0
OVIS_DEVICE=auto
OVIS_DTYPE=auto
OVIS_MAX_PIXELS=131072
OVIS_MAX_NEW_TOKENS=128
OVIS_ENABLE_THINKING=false
