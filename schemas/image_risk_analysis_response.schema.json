{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/image_risk_analysis_response.schema.json",
  "title": "OfficeImageRiskAnalysisResponse",
  "type": "object",
  "required": [
    "image_id",
    "scene_type",
    "people_count_range",
    "risks",
    "overall_severity",
    "needs_review",
    "unsupported_claims",
    "privacy_flags",
    "model_info"
  ],
  "additionalProperties": false,
  "properties": {
    "image_id": {"type": "string", "minLength": 1},
    "scene_type": {
      "type": "string",
      "enum": ["open_office", "meeting_room", "corridor", "lobby", "reception", "server_room", "archive_room", "warehouse_entry", "unknown"]
    },
    "people_count_range": {
      "type": "object",
      "required": ["min", "max"],
      "additionalProperties": false,
      "properties": {
        "min": {"type": "integer", "minimum": 0},
        "max": {"type": "integer", "minimum": 0}
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["risk_type", "severity", "confidence", "evidence", "needs_review"],
        "additionalProperties": false,
        "properties": {
          "risk_type": {
            "type": "string",
            "enum": [
              "fall_or_abnormal_posture",
              "conflict_or_physical_altercation",
              "smoking_or_open_flame",
              "restricted_area_presence",
              "unusual_gathering",
              "camera_obstruction_or_tamper",
              "possible_sensitive_material_capture",
              "badge_or_visitor_pass_missing"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical", "unknown"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": "string",
            "description": "Visible image evidence only. No identity, motive, protected attributes, or legal conclusion."
          },
          "location_hint": {
            "type": "string",
            "description": "Optional natural language location hint, such as left side, near doorway, center table."
          },
          "needs_review": {"type": "boolean"}
        }
      }
    },
    "overall_severity": {
      "type": "string",
      "enum": ["none", "low", "medium", "high", "critical", "unknown"]
    },
    "needs_review": {"type": "boolean"},
    "unsupported_claims": {
      "type": "array",
      "items": {"type": "string"}
    },
    "privacy_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["face_visible", "screen_visible", "whiteboard_visible", "paper_document_visible", "id_badge_visible", "none"]
      }
    },
    "model_info": {
      "type": "object",
      "required": ["provider", "model", "prompt_profile"],
      "additionalProperties": false,
      "properties": {
        "provider": {"type": "string"},
        "model": {"type": "string"},
        "prompt_profile": {"type": "string"},
        "latency_ms": {"type": "integer", "minimum": 0},
        "estimated_cost": {"type": "number", "minimum": 0}
      }
    }
  }
}

